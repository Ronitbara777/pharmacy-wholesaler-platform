generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  role          Role      @default(USER)
  warehouseId   String?
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  movements     StockMovement[]
  notifications Notification[]
  tempDatas     TempData[]
  activities    Activity[]
}

enum Role {
  ADMIN
  MANAGER
  USER
}

// Warehouse model
model Warehouse {
  id          String    @id @default(uuid())
  name        String
  location    String?
  capacity    Float?
  usedSpace   Float?    @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  products    Product[]
  users       User[]
}

// Product model
model Product {
  id              String    @id @default(uuid())
  name            String
  genericName     String?
  batchNumber     String
  expiryDate      DateTime
  quantity        Int       @default(0)
  price           Float
  mrp             Float?
  company         String
  category        String?
  manufacturer    String?
  warehouseId     String
  shelf           String?
  rack            String?
  reorderLevel    Int?      @default(100)
  status          Status    @default(ACTIVE)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  movements       StockMovement[]
  activities      Activity[]
  notifications   Notification[]
}

enum Status {
  ACTIVE
  LOW_STOCK
  OUT_OF_STOCK
  EXPIRED
  DISCONTINUED
}

// Stock Movement
model StockMovement {
  id          String        @id @default(uuid())
  type        MovementType
  quantity    Int
  productId   String
  userId      String
  party       String?
  invoiceNo   String?
  notes       String?
  batchNumber String?
  expiryDate  DateTime?
  price       Float?
  totalAmount Float?
  createdAt   DateTime      @default(now())
  
  // Relations
  product     Product       @relation(fields: [productId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
}

enum MovementType {
  STOCK_IN
  STOCK_OUT
  RETURN_IN
  RETURN_OUT
  ADJUSTMENT
}

// Activity Log
model Activity {
  id          String    @id @default(uuid())
  action      String
  entityType  String
  entityId    String?
  productId   String?
  userId      String
  details     Json?
  ipAddress   String?
  device      String?
  createdAt   DateTime  @default(now())
  
  // Relations
  product     Product?  @relation(fields: [productId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

// Notification
model Notification {
  id          String        @id @default(uuid())
  type        NotificationType
  title       String
  message     String
  severity    Severity      @default(INFO)
  read        Boolean       @default(false)
  userId      String
  productId   String?
  data        Json?
  createdAt   DateTime      @default(now())
  
  // Relations
  user        User          @relation(fields: [userId], references: [id])
  product     Product?      @relation(fields: [productId], references: [id])
}

enum NotificationType {
  EXPIRY
  LOW_STOCK
  SYSTEM
  ALERT
}

enum Severity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Temporary Data
model TempData {
  id          String    @id @default(uuid())
  data        Json
  source      String
  status      String
  userId      String
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  
  // Relations
  user        User      @relation(fields: [userId], references: [id])
}